<ManeuverGroup name="${actor}_slowdonw_reachTTC" maximumExecutionCount="1">
  <Actors selectTriggeringEntities="false">
    <EntityRef entityRef="${actor}"/>
  </Actors>
  <Maneuver name="${actor}_slowdonw_reachTTC_maneuver">
    <Event name="${actor}_slowdonw_reachTTC_event" priority="overwrite">
      <Action name="${actor}_slowdonw_reachTTC_action">
        <PrivateAction>
          <LongitudinalAction>
            <SpeedAction>
              <SpeedActionDynamics
                  dynamicsShape="linear"
                  value="${tv_deceleration}"
                  dynamicsDimension="rate"/>
              <SpeedActionTarget>
                <AbsoluteTargetSpeed value="${tv_decel_speed}"/>
              </SpeedActionTarget>
            </SpeedAction>
          </LongitudinalAction>
        </PrivateAction>
      </Action>
      <StartTrigger>
        <ConditionGroup>
          <Condition name="${actor}_emergency_brake_start"
                     delay="0"
                     conditionEdge="rising">
            <ByValueCondition>
              <SimulationTimeCondition
                  value="${trigger_emergency_brake_time}"
                  rule="greaterThan"/>
            </ByValueCondition>
          </Condition>
        </ConditionGroup>
      </StartTrigger>
    </Event>

    <Event name="${actor}_hold_speed_event" priority="parallel">
      <Action name="${actor}_hold_speed_action">
        <PrivateAction>
          <LongitudinalAction>
            <SpeedAction>
              <SpeedActionDynamics
                  dynamicsShape="step"
                  value="5"
                  dynamicsDimension="time"/>
              <SpeedActionTarget>
                <AbsoluteTargetSpeed value="${tv_decel_speed}"/>
              </SpeedActionTarget>
            </SpeedAction>
          </LongitudinalAction>
        </PrivateAction>
      </Action>
      <StartTrigger>
        <ConditionGroup>
          <Condition name="${actor_hold_after_slowdown_reachTTC}"
                     delay="0"
                     conditionEdge="rising">
            <ByValueCondition>
              <StoryboardElementStateCondition
                  storyboardElementRef="${actor}_slowdonw_reachTTC_event"
                  storyboardElementType="event"
                  state="endTransition"/>
            </ByValueCondition>
          </Condition>
        </ConditionGroup>
      </StartTrigger>
    </Event>
  </Maneuver>
</ManeuverGroup>
